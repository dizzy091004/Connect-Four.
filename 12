#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

#define ROWS 6
#define COLS 7

char board[ROWS][COLS];
char currentPlayer = 'R'; // R: Red, Y: Yellow

void InitializeBoard() {
    for (int r = 0; r < ROWS; r++)
        for (int c = 0; c < COLS; c++)
            board[r][c] = '.';
}

void DrawBoard() {
    printf(" 0 1 2 3 4 5 6\n");
    for (int r = 0; r < ROWS; r++) {
        for (int c = 0; c < COLS; c++)
            printf(" %c", board[r][c]);
        printf("\n");
    }
    printf("---------------\n");
}

bool DropChip(int col) {
    if (col < 0 || col >= COLS) return false;
    for (int r = ROWS - 1; r >= 0; r--) {
        if (board[r][col] == '.') {
            board[r][col] = currentPlayer;
            return true;
        }
    }
    return false;
}

bool CheckDirection(int r, int c, int dr, int dc) {
    char player = board[r][c];
    int count = 0;
    for (int i = 0; i < 4; i++) {
        int nr = r + (dr * i);
        int nc = c + (dc * i);
        if (nr >= 0 && nr < ROWS && nc >= 0 && nc < COLS && board[nr][nc] == player)
            count++;
        else break;
    }
    return count == 4;
}

bool CheckWin() {
    for (int r = 0; r < ROWS; r++) {
        for (int c = 0; c < COLS; c++) {
            if (board[r][c] == '.') continue;
            if (CheckDirection(r, c, 0, 1) || CheckDirection(r, c, 1, 0) || 
                CheckDirection(r, c, 1, 1) || CheckDirection(r, c, 1, -1))
                return true;
        }
    }
    return false;
}

int main() {
    InitializeBoard();
    int moves = 0;
    int col;

    while (true) {
        // 시스템에 따라 화면 지우기 (Windows: cls, Linux/Mac: clear)
        #ifdef _WIN32
            system("cls");
        #else
            system("clear");
        #endif

        DrawBoard();
        printf("플레이어 %c의 차례입니다. 열 번호(0-6)를 입력하세요: ", currentPlayer);

        if (scanf("%d", &col) != 1) {
            while (getchar() != '\n'); // 입력 버퍼 비우기
            continue;
        }

        if (DropChip(col)) {
            moves++;
            if (CheckWin()) {
                #ifdef _WIN32
                    system("cls");
                #else
                    system("clear");
                #endif
                DrawBoard();
                printf("축하합니다! 플레이어 %c가 승리했습니다!\n", currentPlayer);
                break;
            }
            if (moves == ROWS * COLS) {
                DrawBoard();
                printf("무승부입니다!\n");
                break;
            }
            currentPlayer = (currentPlayer == 'R') ? 'Y' : 'R';
        } else {
            printf("잘못된 입력이거나 열이 가득 찼습니다. 엔터를 누르세요.");
            getchar(); getchar(); 
        }
    }
    return 0;
}
